{
  "name": "@planvokter/riotplan-db",
  "version": "1.1.5-dev.0",
  "description": "Abstract interfaces and types for the RiotPlan data access layer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "test": "echo \"No standalone tests yet\"",
    "test:coverage": "npm run test",
    "lint": "echo \"No standalone lint yet\"",
    "precommit": "npm run build && npm run lint && npm run test",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "riotplan",
    "plan",
    "database",
    "repository",
    "interfaces"
  ],
  "author": "Tim O'Brien <tobrien@discursive.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/planvokter/riotplan-db"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
